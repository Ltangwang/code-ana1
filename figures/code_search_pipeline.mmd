%% Edge–cloud code search eval pipeline (evaluate_code_search.py)
%% View with VS Code Mermaid extension, https://mermaid.live, or mermaid-cli for PNG/SVG

flowchart TB
  subgraph init ["Init"]
    A["Load config settings.yaml"] --> B["Load UniXcoder\nlocal checkpoint or microsoft/unixcoder-base"]
    B --> C["Build bi-encoder index from codebase.jsonl\nvector cache npz"]
    C --> D["Load test.jsonl queries"]
    D --> E{"Optional: Cross-Encoder\nOllama health_check"}
  end

  subgraph perq ["Per query"]
    Q["query + GT url"] --> R["Bi-encoder: full-corpus sim rank\ntop retrieve_k"]
    R --> H{"GT in top retrieve_k?"}
    H -->|no| RF["Cloud: rewrite search phrase\n(JSON refined_search_query)"]
    RF --> R50["Bi-encoder: query rewrite\nfull-corpus top cloud_rescue_k"]
    R50 --> CR["Cloud: pick best_index in pool"]
    CR --> MET
    H -->|yes| CE["CE rerank\nor --no-ce skip"]
    CE --> P["Take top llm_pool_k → pool"]
    P --> O["Ollama JSON rerank\nbest_candidate_index + needs_escalation"]
    O --> OK{"Ollama OK\nand no escalation?"}
    OK -->|yes| DONE["ollama_ok"]
    OK -->|no| BUD{"Budget OK?"}
    BUD -->|no| BF["budget_after_ollama_fail"]
    BUD -->|yes| CL["Cloud API rerank"]
    CL --> PAR{"Valid index parse?"}
    PAR -->|no| IP["cloud_invalid_parse"]
    PAR -->|yes| CS["cloud_success_after_fallback"]
  end

  MET["Aggregate metrics"]
  init --> perq
  DONE --> MET
  BF --> MET
  IP --> MET
  CS --> MET
